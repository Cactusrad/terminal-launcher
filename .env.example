# Terminal Launcher Configuration
# Copy this file to .env and fill in your values
# REQUIRED: HOST_IP must be set — the app will not start without it

# Server Configuration (REQUIRED)
HOST_IP=192.168.1.XXX
PORT=80

# Bug Reporting (optional)
# Uses the local bugs_service at http://192.168.1.200:9010
BUGS_API_URL=http://192.168.1.200:9010/api/v1

# Cactus Secrets (preferred — runtime secrets fetched from central service)
# launcher/bugs_api_key and launcher/telegram_{bot_token,chat_id} must exist
# in cactus-secrets. Token scoped read:launcher/*.
SECRETS_URL=http://192.168.1.100:9020
SECRETS_TOKEN=

# Fallbacks (used only if SECRETS_URL/SECRETS_TOKEN are empty or unreachable)
# Leave blank when using cactus-secrets.
BUGS_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Authentication
SECRET_KEY=your-secret-key-here

# Paths (customize for your system)
PROJECTS_DIR=/home/cactus/claude
CLAUDE_CONFIG_DIR=/home/cactus/.claude/projects
