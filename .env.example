# Terminal Launcher Configuration
# Copy this file to .env and fill in your values

# Server Configuration
HOST_IP=192.168.1.100
PORT=80

# Bug Reporting (optional)
# Get your API key from bugs.sharpi.ca or your own bug tracker
BUGS_API_URL=https://your-bug-tracker.com/api/v1
BUGS_API_KEY=YOUR_API_KEY_HERE

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Paths (customize for your system)
PROJECTS_DIR=/home/cactus/claude
CLAUDE_CONFIG_DIR=/home/cactus/.claude/projects
